PORT=3000
BASE_URL=http://localhost:3000

# Required
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/releases

# Optional: Local Postgres credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=releases

# Optional: GitHub API token for better rate limits 60/h vs 5000/h
GITHUB_TOKEN=<YOUR_GITHUB_TOKEN>

# Required: Resend API key for sending emails
RESEND_API_KEY=<YOUR_RESEND_API_KEY>
RESEND_FROM="GitHub Releases <no-reply@episodium.co>"

# Scanner configuration
# Enables in-process cron scanning when true.
SCANNER_CRON_ENABLED=true
# Toad cron format with seconds (default every 5 minutes).
SCANNER_CRON_EXPRESSION=0 */5 * * * *
# Required for /external/scan: send header X-Scanner-Key with this value (not Authorization).
# openssl rand -base64 32
SCANNER_SECRET_KEY=<YOUR_SCANNER_SECRET_KEY>