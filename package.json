{
  "name": "turbo-broccoli",
  "version": "1.0.0",
  "type": "module",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "local:subdomains": "bash scripts/setup-local-subdomains.sh",
    "build": "node scripts/build.mjs",
    "typecheck": "tsc",
    "lint": "eslint .",
    "start": "node dist/index.js",
    "web:css": "tailwindcss -i ./src/web/input.css -o ./dist/public/web.css --minify",
    "email:build": "maizzle build --config maizzle.config.cjs",
    "email:serve": "maizzle serve --config maizzle.config.cjs",
    "generate:types": "pnpm exec openapi-typescript ./src/docs/openapi.yaml -o ./src/types/openapi.d.ts",
    "db:generate": "drizzle-kit generate",
    "test": "vitest run --config tests/config/vitest.config.ts",
    "test:watch": "vitest --config tests/config/vitest.config.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/schedule": "^6.0.0",
    "@fastify/static": "^9.1.0",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.4",
    "octokit": "^5.0.5",
    "pg": "^8.20.0",
    "resend": "^6.10.0",
    "toad-scheduler": "^3.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@maizzle/cli": "^2.0.0",
    "@maizzle/framework": "^5.5.0",
    "@tailwindcss/cli": "^4.2.2",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "openapi-typescript": "^5.4.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^2.1.9"
  }
}
