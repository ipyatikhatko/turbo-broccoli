    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.4",
    "octokit": "^5.0.5",
    "openapi-types": "^12.1.3",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.0",
